# n4d-mcp-worm.rules
# n4d/NadMesh: C2-Coordinated Propagation System Weaponizes MCP
# https://github.com/boredchilada/cyfar-detections
#
# 1000637001  Ingress  - external MCP JSON-RPC initialize (anomalous where MCP is local-only)
# 1000637002  Egress   - agent download from the Mesh Control C2 IP
# 1000637003  Egress   - agent download from the cdnorigin.net update domain

alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"MCP JSON-RPC initialize from external source"; flow:to_server,established; http.method; content:"POST"; http.request_body; content:"jsonrpc"; content:"initialize"; distance:0; within:80; content:"protocolVersion"; distance:0; within:120; classtype:attempted-admin; sid:1000637001; rev:1; metadata:created_at 2026_07_10, deployment Ingress;)

alert http $HOME_NET any -> 209.99.186.235 any (msg:"N4D Worm - Agent download from Mesh Control C2"; flow:to_server,established; http.uri; content:"/api/agent/"; classtype:trojan-activity; sid:1000637002; rev:2; metadata:created_at 2026_07_10, deployment Egress;)

alert http $HOME_NET any -> any any (msg:"N4D Worm - Agent download from cdnorigin.net"; flow:to_server,established; http.host; content:"cdnorigin.net"; http.uri; content:"/api/agent/"; classtype:trojan-activity; sid:1000637003; rev:2; metadata:created_at 2026_07_10, deployment Egress;)
